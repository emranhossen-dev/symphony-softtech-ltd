              </div>
              {/* Bottom Progress Bar for Video */}
              <div className="absolute bottom-0 left-0 w-full h-1 bg-white/10">
                <div className="h-full bg-emerald-500 w-[65%]"></div>
              </div>
            </div>

            <div className="mt-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
              <div>
                <div className="flex items-center gap-2 mb-1">
                  <span className="px-2 py-0.5 bg-emerald-500/10 text-emerald-400 text-xs font-semibold rounded uppercase">Active</span>
                  <span className="text-slate-400 text-xs">• Module 3, Lesson 3 of 12</span>
                </div>
                <h2 className="text-2xl font-bold text-slate-100">3. Prototyping Interactions</h2>
              </div>
              <div className="flex items-center gap-3">
                <button className="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-700 text-slate-300 text-sm font-medium hover:bg-slate-800 active:scale-95 transition-all">
                  <span className="material-symbols-outlined text-base">chevron_left</span>
                  Previous
                </button>
                <button className="flex items-center gap-2 px-5 py-2 rounded-lg bg-emerald-500 text-slate-950 text-sm font-bold hover:brightness-110 active:scale-95 transition-all">
                  Next Lesson
                  <span className="material-symbols-outlined text-base">chevron_right</span>
                </button>
              </div>
            </div>
          </section>

          {/* TABS & UTILITY CONTENT */}
          <section className="flex-1 flex flex-col min-w-0">
            <div className="flex items-center border-b border-slate-800 mb-6">
              <TabButton active={activeTab === 'notes'} onClick={() => setActiveTab('notes')} icon="description" label="Notes" />
              <TabButton active={activeTab === 'homework'} onClick={() => setActiveTab('homework')} icon="task" label="Homework" />
              <TabButton active={activeTab === 'resources'} onClick={() => setActiveTab('resources')} icon="folder_open" label="Resources" />
              <TabButton active={activeTab === 'practice'} onClick={() => setActiveTab('practice')} icon="terminal" label="Practice" />
            </div>

            {/* Content Area dynamic presentation depending on choice */}
            {activeTab === 'notes' && (
              <div className="space-y-6">
                <div className="bg-slate-900 rounded-xl border border-slate-800 p-4 shadow-sm">
                  <div className="flex items-center justify-between mb-4">
                    <div className="flex items-center gap-1 bg-slate-800/50 rounded-lg p-1">
                      <button className="p-1.5 hover:bg-slate-800 rounded text-slate-400 hover:text-slate-200"><span className="material-symbols-outlined text-lg">format_bold</span></button>
                      <button className="p-1.5 hover:bg-slate-800 rounded text-slate-400 hover:text-slate-200"><span className="material-symbols-outlined text-lg">format_italic</span></button>
                      <button className="p-1.5 hover:bg-slate-800 rounded text-slate-400 hover:text-slate-200"><span className="material-symbols-outlined text-lg">format_list_bulleted</span></button>
                      <div className="w-[1px] h-4 bg-slate-800 mx-1"></div>
                      <button className="p-1.5 hover:bg-slate-800 rounded text-slate-400 hover:text-slate-200"><span className="material-symbols-outlined text-lg">link</span></button>
                      <button className="p-1.5 hover:bg-slate-800 rounded text-slate-400 hover:text-slate-200"><span className="material-symbols-outlined text-lg">code</span></button>
                    </div>
                    <button 
                      onClick={() => { if(noteText.trim()) alert('Note Saved: ' + noteText); setNoteText(''); }}
                      className="px-4 py-1.5 bg-emerald-500 text-slate-950 text-sm font-bold rounded-lg hover:brightness-110 active:scale-95 transition-all"
                    >
                      Save Note
