      />

      {/* SIDEBAR NAVIGATION */}
      <aside className="fixed left-0 top-0 h-full w-[280px] bg-slate-900 border-r border-slate-800 flex flex-col py-6 shadow-sm z-50">
        <div className="px-6 mb-8">
