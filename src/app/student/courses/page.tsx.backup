}

// Sub-components for cleaner internal structuring
function SidebarLink({ icon, label, active = false }: SidebarLinkProps) {
  return (
    <a 
      className={`flex items-center gap-3 px-4 py-3 rounded-lg transition-all duration-200 text-sm font-medium ${
        active 
          ? 'bg-emerald-500/10 text-emerald-400 border-l-4 border-emerald-500 font-semibold' 
          : 'text-slate-400 hover:bg-slate-800/50 hover:text-slate-200'
      }`} 
      href="#"
    >
      <span className={`material-symbols-outlined ${active ? '!fill-1' : ''}`}>{icon}</span>
      <span>{label}</span>
    </a>
  );
}

function TabButton({ active, onClick, icon, label }: { active: boolean; onClick: () => void; icon: string; label: string }) {
  return (
    <button 
      onClick={onClick}
      className={`px-6 py-4 border-b-2 font-medium text-sm flex items-center gap-2 transition-all duration-200 ${
        active 
          ? 'border-emerald-500 text-emerald-400 font-semibold' 
          : 'border-transparent text-slate-400 hover:text-slate-200'
      }`}
    >
      <span className={`material-symbols-outlined text-xl ${active ? '!fill-1' : ''}`}>{icon}</span>
      {label}
    </button>
  );
}

function NoteCard({ date, title, excerpt }: NoteCardProps) {
  return (
    <div className="p-4 bg-slate-900 rounded-xl border border-slate-800 hover:border-emerald-500/30 transition-all cursor-pointer group shadow-sm">
      <div className="flex justify-between items-start mb-2">
        <span className="text-[11px] text-slate-500">{date}</span>
        <span className="material-symbols-outlined text-lg text-slate-500 opacity-0 group-hover:opacity-100 transition-opacity">more_vert</span>
      </div>
      <h4 className="text-sm font-bold text-slate-200 mb-1 group-hover:text-emerald-400 transition-colors">{title}</h4>
      <p className="text-xs text-slate-400 line-clamp-2 leading-relaxed">{excerpt}</p>
    </div>
  );
}

function LessonItem({ number, title, type, duration, status }: LessonItemProps) {
  if (status === 'locked') {
    return (
      <div className="p-4 flex items-center gap-4 opacity-40 cursor-not-allowed bg-slate-950/20">
        <div className="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-slate-500">
          <span className="material-symbols-outlined text-lg">lock</span>
        </div>
        <div className="flex-1">
          <h4 className="text-sm font-medium text-slate-400">{number}. {title}</h4>
          <p className="text-xs text-slate-600">{type} • {duration}</p>
        </div>
      </div>
    );
  }

  const isActive = status === 'active';

  return (
    <div className={`p-4 flex items-center gap-4 transition-colors cursor-pointer ${isActive ? 'bg-emerald-500/5 border-l-4 border-emerald-500' : 'hover:bg-slate-800/30'}`}>
      <div className={`w-10 h-10 rounded-full flex items-center justify-center ${isActive ? 'bg-emerald-500 text-slate-950' : 'bg-emerald-500/10 text-emerald-400'}`}>
        <span className="material-symbols-outlined text-lg !fill-1">
          {isActive ? 'graphic_eq' : 'check_circle'}
        </span>
      </div>
      <div className="flex-1">
        <h4 className={`text-sm ${isActive ? 'font-bold text-emerald-400' : 'font-medium text-slate-300'}`}>
          {number}. {title}
        </h4>
        <p className={`text-xs ${isActive ? 'text-emerald-500/80' : 'text-slate-500'}`}>
          {type} • {duration}
        </p>
      </div>
    </div>
  );
}
                  <div className={`text-xs ${selectedCourse?.id === course.id ? 'text-green-100' : 'text-gray-500'}`}>
                    {course.progress}% complete
                  </div>
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>

      {/* Split Layout */}
      {selectedCourse && (
        <div className="flex h-screen">
          {/* Main Content Area */}
          <div className="flex-1 flex flex-col bg-gray-900">
            {/* Video Player - Fixed responsive height */}
            <div className="relative bg-black flex-shrink-0">
              <div className="w-full aspect-video bg-gray-900 flex items-center justify-center">
                <Video className="w-16 h-16 text-gray-600" />
                <div className="absolute text-white text-lg">Video Player</div>
              </div>
            </div>

            {/* Previous/Next Navigation */}
            <div className="bg-gray-800 px-4 py-3 flex items-center justify-between border-b border-gray-700">
              <button 
                onClick={goToPreviousModule}
                disabled={currentModuleIndex === 0}
                className={`flex items-center space-x-2 px-4 py-2 rounded-lg transition-colors ${
                  currentModuleIndex === 0 
                    ? 'bg-gray-700 text-gray-500 cursor-not-allowed' 
                    : 'bg-gray-700 hover:bg-gray-600 text-white'
                }`}
              >
                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 19l-7-7 7-7" />
                </svg>
                <span className="text-sm font-medium">Previous</span>
              </button>
              
              <div className="text-center">
                <p className="text-sm font-medium text-white">
                  {currentModuleIndex + 1}/{modules.length}
                </p>
                <p className="text-xs text-gray-400">
                  {currentModule?.title || 'No video selected'}
                </p>
              </div>
              
              <button 
                onClick={goToNextModule}
                disabled={currentModuleIndex >= modules.length - 1 || (modules[currentModuleIndex + 1]?.isLocked)}
                className={`flex items-center space-x-2 px-4 py-2 rounded-lg transition-colors ${
                  currentModuleIndex >= modules.length - 1 || (modules[currentModuleIndex + 1]?.isLocked)
                    ? 'bg-gray-700 text-gray-500 cursor-not-allowed'
                    : 'bg-green-600 hover:bg-green-700 text-white'
                }`}
              >
                <span className="text-sm font-medium">Next</span>
                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5l7 7-7 7" />
                </svg>
              </button>
            </div>

            {/* Action Buttons Section */}
            <div className="bg-gray-800 px-4 py-3 border-b border-gray-700">
              <div className="grid grid-cols-4 gap-2">
                <button
                  onClick={() => setActiveSection('notes')}
                  className={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                    activeSection === 'notes'
                      ? 'bg-green-600 text-white'
                      : 'bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white'
                  }`}
                >
                  <FileText className="w-4 h-4 mx-auto mb-1" />
                  <div>Notes</div>
                </button>
                <button
                  onClick={() => setActiveSection('homework')}
                  className={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                    activeSection === 'homework'
                      ? 'bg-green-600 text-white'
                      : 'bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white'
                  }`}
                >
                  <BookOpen className="w-4 h-4 mx-auto mb-1" />
                  <div>Homework</div>
                </button>
                <button
                  onClick={() => setActiveSection('resources')}
                  className={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                    activeSection === 'resources'
                      ? 'bg-green-600 text-white'
                      : 'bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white'
                  }`}
                >
                  <Download className="w-4 h-4 mx-auto mb-1" />
                  <div>Resources</div>
                </button>
                <button
                  onClick={() => setActiveSection('practice')}
                  className={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                    activeSection === 'practice'
                      ? 'bg-green-600 text-white'
                      : 'bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white'
                  }`}
                >
                  <Play className="w-4 h-4 mx-auto mb-1" />
                  <div>Practice</div>
                </button>
              </div>
            </div>

            {/* Content Section */}
            <div className="flex-1 bg-gray-900 p-4 overflow-hidden min-h-[600px]">
              {/* Notes Content */}
              {activeSection === 'notes' && (
                <div className="bg-gray-800 rounded-lg p-4 h-full overflow-y-auto">
                  <div className="space-y-4">
                    <div>
                      <input
                        type="text"
                        placeholder="Note Title"
                        value={noteTitle}
                        onChange={(e) => setNoteTitle(e.target.value)}
                        className="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500"
                      />
                    </div>
                    <div>
                      <textarea
                        placeholder="Write Something Awesome..."
                        value={noteContent}
                        onChange={(e) => setNoteContent(e.target.value)}
                        className="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 h-32 resize-none"
                      />
                    </div>
                    <div className="flex items-center justify-between">
                      <div className="flex space-x-2">
                        <button className="p-2 text-gray-400 hover:text-white hover:bg-gray-700 rounded">
                          <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 10V3L4 14h7v7l9-11h-7z" />
                          </svg>
                        </button>
                        <button className="p-2 text-gray-400 hover:text-white hover:bg-gray-700 rounded">
                          <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 6h16M4 12h16m-7 6h7" />
                          </svg>
                        </button>
                      </div>
                      <button 
                        onClick={saveNote}
                        className="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg font-medium transition-colors"
                      >
                        Save Note
                      </button>
                    </div>
                    
                    {/* Display Saved Notes */}
                    {savedNotes.length > 0 && (
                      <div className="mt-6 space-y-3">
                        <h3 className="text-lg font-semibold text-white">Your Notes</h3>
                        {savedNotes.map((note) => (
                          <div key={note.id} className="bg-gray-700 rounded-lg p-3">
                            <div className="flex items-start justify-between">
                              <div className="flex-1">
                                <h4 className="font-medium text-white">{note.title}</h4>
                                <p className="text-gray-300 text-sm mt-1">{note.content}</p>
                                <p className="text-xs text-gray-400 mt-2">
                                  {note.moduleName} • {new Date(note.createdAt).toLocaleDateString()}
                                </p>
                              </div>
                              <button 
                                onClick={() => {
                                  setSavedNotes(savedNotes.filter(n => n.id !== note.id));
                                }}
                                className="ml-2 p-1 text-gray-400 hover:text-red-400"
                              >
                                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                                </svg>
                              </button>
                            </div>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              )}

              {/* Homework Content */}
              {activeSection === 'homework' && (
                <div className="bg-gray-800 rounded-lg p-4 h-full overflow-y-auto">
                  <div className="space-y-4">
                    <div>
                      <h3 className="text-lg font-semibold text-white mb-2">Homework Instructions</h3>
                      <div className="bg-gray-700 rounded-lg p-4">
                        <p className="text-gray-300">
                          Complete the following coding exercises to practice what you've learned in this module.
                          Follow the instructions carefully and submit your work before the deadline.
                        </p>
                      </div>
                    </div>
                    <div className="flex justify-center">
                      <button 
                        onClick={() => {
                          // Navigate to homework page or open homework modal
                          window.location.href = `/student/homework?courseId=${selectedCourse?.id}&moduleId=${currentModule?.id}`;
                        }}
                        className="px-6 py-3 bg-green-600 hover:bg-green-700 text-white rounded-lg font-medium transition-colors flex items-center space-x-2"
                      >
                        <Play className="w-5 h-5" />
                        <span>Start Homework</span>
                      </button>
                    </div>
                  </div>
                </div>
              )}

              {/* Resources Content */}
              {activeSection === 'resources' && (
                <div className="bg-gray-800 rounded-lg p-4 h-full overflow-y-auto">
                  <div className="space-y-4">
                    <h3 className="text-lg font-semibold text-white mb-2">Class Resources</h3>
                    <div className="space-y-2">
                      <div 
                        onClick={() => {
                          // Download module slides
                          const link = document.createElement('a');
                          link.href = '/api/resources/module-slides';
                          link.download = 'module-slides.pdf';
                          link.click();
                        }}
                        className="bg-gray-700 rounded-lg p-3 hover:bg-gray-600 transition-colors cursor-pointer"
                      >
                        <div className="flex items-center justify-between">
                          <div className="flex items-center space-x-3">
                            <FileText className="w-5 h-5 text-green-400" />
                            <span className="text-white">Module Slides</span>
                          </div>
                          <Download className="w-4 h-4 text-gray-400" />
                        </div>
                      </div>
                      <div 
                        onClick={() => {
                          // Download reading material
                          const link = document.createElement('a');
                          link.href = '/api/resources/reading-material';
                          link.download = 'reading-material.pdf';
                          link.click();
                        }}
                        className="bg-gray-700 rounded-lg p-3 hover:bg-gray-600 transition-colors cursor-pointer"
                      >
                        <div className="flex items-center justify-between">
                          <div className="flex items-center space-x-3">
                            <FileText className="w-5 h-5 text-blue-400" />
                            <span className="text-white">Reading Material</span>
                          </div>
                          <Download className="w-4 h-4 text-gray-400" />
                        </div>
                      </div>
                      <div 
                        onClick={() => {
                          // Open reference links in new tab
                          window.open('https://example.com/reference-links', '_blank');
                        }}
                        className="bg-gray-700 rounded-lg p-3 hover:bg-gray-600 transition-colors cursor-pointer"
                      >
                        <div className="flex items-center justify-between">
                          <div className="flex items-center space-x-3">
                            <FileText className="w-5 h-5 text-purple-400" />
                            <span className="text-white">Reference Links</span>
                          </div>
                          <svg className="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {/* Practice Content */}
              {activeSection === 'practice' && (
                <div className="bg-gray-800 rounded-lg p-4 h-full overflow-y-auto">
                  <div className="space-y-4">
                    <h3 className="text-lg font-semibold text-white mb-2">Practice Area</h3>
                    <div className="bg-gray-700 rounded-lg p-4">
                      <p className="text-gray-300 mb-4">
                        Practice your coding skills here. Write code and see the results in real-time.
                      </p>
                      <div className="bg-gray-900 rounded-lg p-4 font-mono text-sm text-gray-300">
                        <textarea
                          value={code}
                          onChange={(e) => setCode(e.target.value)}
                          className="w-full bg-transparent text-gray-300 font-mono text-sm resize-none outline-none"
                          rows={6}
                          placeholder="// Write your code here..."
                        />
                      </div>
                      
                      {/* Output Section */}
                      {codeOutput && (
                        <div className="mt-4 bg-gray-900 rounded-lg p-4">
                          <h4 className="text-sm font-semibold text-green-400 mb-2">Output:</h4>
                          <pre className="text-gray-300 text-sm font-mono">{codeOutput}</pre>
                        </div>
                      )}
                    </div>
                    <div className="flex justify-center">
                      <button 
                        onClick={() => {
                          try {
                            // Simple code execution simulation
                            const output = [];
                            const originalLog = console.log;
                            console.log = (...args) => {
                              output.push(args.join(' '));
                            };
                            
                            // Execute the code (in a real app, this should be done in a sandbox)
                            eval(code);
                            
                            console.log = originalLog;
                            setCodeOutput(output.join('\n') || 'Code executed successfully (no output)');
                          } catch (error) {
                            setCodeOutput(`Error: ${error.message}`);
                          }
                        }}
                        className="px-6 py-3 bg-green-600 hover:bg-green-700 text-white rounded-lg font-medium transition-colors flex items-center space-x-2"
                      >
                        <Play className="w-5 h-5" />
                        <span>Run Code</span>
                      </button>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>

          {/* Right Sidebar - Modules */}
          <div className="w-80 bg-gray-800 flex flex-col h-full">
            {/* Running Module Indicator */}
            <div className="p-4 border-b border-gray-700 flex-shrink-0">
              <div className="flex items-center justify-between mb-2">
                <span className="text-sm font-medium text-gray-300">Running Module:</span>
                <span className="text-sm font-bold text-green-400">14</span>
              </div>
              <div className="w-full bg-gray-700 rounded-full h-2">
                <div className="bg-green-500 h-2 rounded-full" style={{ width: '100%' }}></div>
              </div>
              <div className="flex items-center justify-between mt-1">
                <span className="text-xs text-gray-400">11/11 Completed</span>
                <span className="text-xs text-green-400">100%</span>
              </div>
            </div>

            {/* Search Bar */}
            <div className="p-4 border-b border-gray-700 flex-shrink-0">
              <div className="relative">
                <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-4 h-4" />
                <input
                  type="text"
                  placeholder="Search Lesson"
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                  className="w-full pl-10 pr-4 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500"
                />
              </div>
            </div>

            
            {/* Modules List */}
            <div className="flex-1 overflow-y-auto min-h-0">
              <div className="p-2 space-y-1">
                {filteredModules.length === 0 ? (
                  <div className="p-8 text-center text-gray-500">
                    <BookOpen className="w-12 h-12 mx-auto mb-3 text-gray-300" />
                    <p>No modules found</p>
                  </div>
                ) : (
                  filteredModules.map((module, index) => {
                    const originalIndex = modules.findIndex(m => m.id === module.id);
                    const isCurrentModule = originalIndex === currentModuleIndex;
                    
                    return (
                      <div
                        key={module.id}
                        onClick={() => selectModule(originalIndex)}
                        className={`p-3 rounded-lg cursor-pointer transition-colors ${
                          isCurrentModule
                            ? 'bg-gray-700 border-l-4 border-green-500'
                            : 'hover:bg-gray-700'
                        }`}
                      >
                        <div className="flex items-start space-x-3">
                          <div className="flex-shrink-0 mt-1">
                            {module.isCompleted ? (
                              <div className="w-4 h-4 bg-green-500 rounded-full flex items-center justify-center">
                                <svg className="w-2 h-2 text-white" fill="currentColor" viewBox="0 0 20 20">
                                  <path fillRule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clipRule="evenodd" />
                                </svg>
                              </div>
                            ) : module.isLocked ? (
                              <div className="w-4 h-4 bg-gray-600 rounded-full flex items-center justify-center">
                                <span className="text-xs text-gray-400">🔒</span>
                              </div>
                            ) : (
                              <div className="w-4 h-4 bg-blue-500 rounded-full flex items-center justify-center">
                                <span className="text-xs text-white font-bold">{index + 1}</span>
                              </div>
                            )}
                          </div>
                          
                          <div className="flex-1 min-w-0">
                            <h4 className="text-sm font-medium text-white truncate">
                              {module.title}
                            </h4>
                            <div className="flex items-center mt-1 text-xs text-gray-400">
                              <Clock className="w-3 h-3 mr-1" />
                              <span>{module.duration}</span>
                            </div>
                          </div>
                        </div>
                      </div>
                    );
                  })
                )}
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
