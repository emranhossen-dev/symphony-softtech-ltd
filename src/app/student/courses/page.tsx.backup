                    placeholder="Start typing your module notes here..."
                  />
                </div>

                {/* Previous Notes Cards */}
                <div className="space-y-4">
                  <div className="flex items-center justify-between">
                    <h3 className="text-xs font-bold text-slate-400 uppercase tracking-wider">Your Saved Notes</h3>
                    <button className="text-emerald-400 text-xs font-semibold hover:underline">View All</button>
                  </div>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <NoteCard 
                      date="Oct 24, 11:20 AM" 
                      title="Defining trigger points" 
                      excerpt="Interaction triggers can be manual like clicks or automatic like timers. Remember to keep the..." 
                    />
                    <NoteCard 
                      date="Oct 23, 03:45 PM" 
                      title="Figma Prototyping Hacks" 
                      excerpt="Use overlays for dropdowns and sidebars to keep your main flows clean and manageable..." 
                    />
                  </div>
                </div>
              </div>
            )}

            {activeTab !== 'notes' && (
              <div className="flex items-center justify-center h-48 border border-dashed border-slate-800 rounded-xl text-slate-500 text-sm">
                Content interface ready for active tab section layout.
              </div>
            )}
          </section>
        </div>

        {/* MODULE SYLLABUS (RIGHT COLUMN) */}
        <aside className="w-[360px] flex flex-col bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-sm">
          <div className="p-6 border-b border-slate-800 bg-slate-800/20">
            <div className="flex items-center justify-between mb-2">
              <h3 className="text-lg font-bold text-slate-100">Module 3: Prototyping</h3>
              <span className="px-2 py-0.5 bg-emerald-500 text-slate-950 text-[10px] font-bold rounded uppercase">Active</span>
            </div>
            <div className="flex items-center justify-between mb-3">
              <span className="text-xs text-slate-400">Overall Progress</span>
              <span className="text-xs text-emerald-400 font-bold">85%</span>
            </div>
            <div className="w-full h-1.5 bg-slate-800 rounded-full overflow-hidden">
              <div className="h-full bg-emerald-500 rounded-full transition-all duration-500" style={{ width: '85%' }}></div>
            </div>
          </div>

          <div className="flex-1 overflow-y-auto scrollbar-none divide-y divide-slate-800/60">
            <LessonItem number={1} title="Intro to High Fidelity" type="Video" duration="12:15" status="completed" />
            <LessonItem number={2} title="User Flow Mapping" type="Video" duration="18:30" status="completed" />
            <LessonItem number={3} title="Prototyping Interactions" type="Playing" duration="15:20" status="active" />
            <LessonItem number={4} title="Advanced Transitions" type="Video" duration="14:10" status="locked" />
            <LessonItem number={5} title="Auto Animate Techniques" type="Video" duration="22:45" status="locked" />
            <LessonItem number={6} title="Interactive Components" type="Video" duration="19:10" status="locked" />
          </div>

          <div className="p-6 border-t border-slate-800 bg-slate-900">
            <button className="w-full flex items-center justify-center gap-2 py-3 rounded-xl border border-emerald-500/30 text-emerald-400 text-sm font-bold hover:bg-emerald-500/10 active:scale-[0.98] transition-all">
              <span className="material-symbols-outlined text-lg">download</span>
              Download Syllabus
            </button>
          </div>
        </aside>
      </main>
