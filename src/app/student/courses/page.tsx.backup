              <span className="material-symbols-outlined">notifications</span>
            </button>
            <button className="p-2 text-slate-400 hover:text-emerald-400 active:scale-95 transition-all">
              <span className="material-symbols-outlined">dark_mode</span>
            </button>
          </div>
          <div className="h-8 w-[1px] bg-slate-800"></div>
          <div className="flex items-center gap-3 group cursor-pointer">
            <div className="text-right">
              <p className="text-sm font-semibold text-slate-200 group-hover:text-emerald-400 transition-colors">Alex Morgan</p>
              <p className="text-[11px] text-slate-400 leading-none mt-0.5">Senior Student</p>
            </div>
            <img 
              alt="User Profile" 
              className="w-9 h-9 rounded-full border border-emerald-500/30 object-cover" 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAEyx73Zt-RLJ8I5XO7gaxturu3g_YZ-CjUy_XvPl8nsKi5ZVddHRAg4YNvmUUgBp_jF6PBAK3BmOsy9_IW20KRuqSDyU5S5GUu8eHTbPCoN0-oZZUNVpIer4TKiQbnKhFnBGQrfPD-g24L_ziawUbSFmHdbQOd0fiFTzflZbQ9KAG5Un2VJDUnYz-_4IDsq-LUwLUuIGfUWzR2Q9XsxbPnMrCj8ueMG5vP1t3z6JUXQFCD0pq14xZttOyjQ7joUffe8j3m0HqxRzT6"
            />
          </div>
        </div>
      </header>

      {/* MAIN CONTENT CANVAS */}
      <main className="ml-[280px] mt-16 p-6 flex h-[calc(100vh-64px)] gap-6 overflow-hidden">
        
        {/* MODULE LEARNING CENTER (MIDDLE COLUMN) */}
        <div className="flex-1 flex flex-col min-w-0 space-y-6 overflow-y-auto pr-2 scrollbar-thin scrollbar-thumb-emerald-500/20 scrollbar-track-transparent">
          
          {/* VIDEO PLAYER SECTION */}
          <section className="relative group">
            <div className="aspect-video w-full rounded-2xl overflow-hidden bg-slate-800/70 backdrop-blur-md border border-slate-800 relative shadow-inner">
              <img 
                alt="Course Video Placeholder" 
                className="w-full h-full object-cover opacity-80" 
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCylKL-MzF_LWNzhA-rKG589fZlxIymbC68LwAM_pNi7QHZqwCRrD8ZPtUwbTTc3IzfWzvOmepfVLlp_dD9CVtEmOdSLbU-W5hBKEcCkaHACtoVE-ZmXqf9xpZ65_hLB_BmGWMR7y6rGUgJu04uL1tryb20wSneNcqAldJRsc5n2OZ-vhbUmbl16xoxX9vxNXVoqg9C5CA2T2pVmHdBCrf6FG_-GOhH1KfGZCQOGbsnox883QPEmmtLcAKbknMRtnY1DlGbVNYKDHcR"
              />
              {/* Video Controls Overlay */}
              <div className="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
