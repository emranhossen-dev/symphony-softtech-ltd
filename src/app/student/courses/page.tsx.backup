        <div className="flex items-center gap-4">
          <div className="flex items-center gap-2 text-slate-400 text-sm">
            <a className="hover:text-emerald-400 transition-colors" href="#modules">Modules</a>
            <span className="material-symbols-outlined text-base">chevron_right</span>
            <span className="text-emerald-400 font-semibold">Advanced UX Design</span>
          </div>
        </div>

        <div className="flex-1 max-w-md mx-8">
          <div className="relative group">
            <span className="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-emerald-400 transition-colors">
              search
